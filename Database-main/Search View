CREATE VIEW searchable_documents AS

SELECT

    d.id,
    d.title,
    d.description,
    d.file_name,

    c.category_name,

    STRING_AGG(t.tag_name, ', ') AS tags

FROM documents d

LEFT JOIN categories c
ON d.category_id = c.id

LEFT JOIN document_tags dt
ON d.id = dt.document_id

LEFT JOIN tags t
ON dt.tag_id = t.id

GROUP BY
    d.id,
    c.category_name;
